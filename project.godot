; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited directly if you know what you're doing.

config_version=5

[application]

config/name="Crypt Clicker"
config/description="Stage-based necromancer defense roguelike. Defend your crypt as a disembodied necromancer hand."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.0", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=640
window/size/viewport_height=480
window/size/window_width_override=1280
window/size/window_height_override=960
window/stretch/mode="viewport"
window/stretch/aspect="keep"

